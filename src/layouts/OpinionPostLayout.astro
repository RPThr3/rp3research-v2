---
import Layout from './Layout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'opinion'>;
  categoryLabel: string;
}

const { post, categoryLabel } = Astro.props;
const { title, date, readTime } = post.data;
const formattedDate = date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---
<Layout title={`${title} — RP3 Research`}>
  <article class="post-page">
    <div class="container">

      <a href="/opinion" class="back-link">← Back to Opinion</a>

      <header class="post-header">
        <div class="post-meta">
          <span class="post-category">{categoryLabel}</span>
          <span class="post-dot">·</span>
          <span class="post-date">{formattedDate}</span>
          <span class="post-dot">·</span>
          <span class="post-read">{readTime} min read</span>
        </div>
        <h1 class="post-headline">{title}</h1>
        <div class="post-byline">
          <span class="byline-name">Reed Perry</span>
        </div>
      </header>

      <div class="post-body">
        <slot />
      </div>

      <div class="post-signature">
        <div class="sig-rule"></div>
        <div class="sig-inner">
          <div class="sig-name">Reed Perry</div>
          <div class="sig-title">RP3 Research · Charlotte, NC</div>
        </div>
      </div>

      <a href="/opinion" class="back-link back-link--bottom">← Back to Opinion</a>

    </div>
  </article>
</Layout>

<style>
  .post-page { padding-top:var(--nav-h); padding-bottom:clamp(80px,12vw,160px); }
  .container { max-width:780px; }
  .back-link { display:inline-block; font-size:12px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-muted); margin-block:clamp(32px,4vw,56px); transition:color 0.2s; }
  .back-link:hover { color:var(--ink); }
  .back-link--bottom { margin-top:64px; margin-bottom:0; }
  .post-header { margin-bottom:64px; }
  .post-meta { display:flex; align-items:center; gap:8px; margin-bottom:24px; flex-wrap:wrap; }
  .post-category { font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:var(--accent); font-weight:500; }
  .post-dot { color:var(--ink-faint); font-size:12px; }
  .post-date, .post-read { font-size:12px; color:var(--ink-faint); letter-spacing:0.04em; }
  .post-headline { font-family:var(--font-display); font-size:clamp(28px,4vw,52px); font-weight:300; line-height:1.1; letter-spacing:-0.01em; color:var(--ink); margin-bottom:24px; }
  .post-byline { font-size:13px; color:var(--ink-muted); font-weight:300; }
  .byline-name { font-weight:400; color:var(--ink); }
  /* Prose styles for MDX content */
  .post-body { display:flex; flex-direction:column; gap:24px; margin-bottom:56px; }
  .post-body :global(h2) { font-family:var(--font-display); font-size:clamp(20px,2.2vw,28px); font-weight:400; color:var(--ink); line-height:1.2; margin-top:16px; margin-bottom:4px; }
  .post-body :global(p) { font-size:16px; line-height:1.85; color:var(--ink-muted); font-weight:300; }
  .post-body :global(em) { font-style:italic; }
  .post-body :global(strong) { color:var(--ink); font-weight:500; }
  .post-body :global(cite) { font-style:normal; font-size:11px; letter-spacing:0.06em; color:var(--ink-faint); font-weight:400; white-space:nowrap; }
  .post-body :global(cite::before) { content:'['; }
  .post-body :global(cite::after) { content:']'; }
  .post-body :global(ul) { display:flex; flex-direction:column; gap:16px; padding-left:0; list-style:none; }
  .post-body :global(li) { font-size:16px; line-height:1.85; color:var(--ink-muted); font-weight:300; padding-left:20px; position:relative; }
  .post-body :global(li::before) { content:'—'; position:absolute; left:0; color:var(--accent); font-size:14px; top:2px; }
  .post-body :global(li strong) { color:var(--ink); font-weight:500; }
  .post-body :global(.post-attribution) { font-size:12px; color:var(--ink-faint); font-style:italic; font-weight:300; line-height:1.7; }
  .post-signature { margin-bottom:8px; }
  .sig-rule { height:1px; background:var(--rule); margin-bottom:24px; }
  .sig-inner { display:flex; flex-direction:column; gap:4px; }
  .sig-name { font-family:var(--font-display); font-size:20px; font-weight:400; color:var(--ink); }
  .sig-title { font-size:12px; color:var(--ink-faint); letter-spacing:0.06em; font-weight:300; }
</style>
