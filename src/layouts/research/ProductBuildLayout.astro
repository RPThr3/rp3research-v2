---
import ResearchPostLayout from '../ResearchPostLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'research'>;
  stack?: string[];
}
const { post, stack } = Astro.props;
---
<ResearchPostLayout post={post} categoryLabel="Product Build">
  {stack && stack.length > 0 && (
    <div class="stack-strip">
      <span class="stack-label">Stack</span>
      <div class="stack-tags">
        {stack.map(s => <span class="stack-tag">{s}</span>)}
      </div>
    </div>
  )}
  <slot />
</ResearchPostLayout>

<style>
  .stack-strip { display:flex; align-items:center; gap:20px; padding:16px 0; border-bottom:1px solid var(--rule); margin-bottom:clamp(44px,6vw,64px); }
  .stack-label { font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-faint); font-weight:500; white-space:nowrap; }
  .stack-tags { display:flex; flex-wrap:wrap; gap:8px; }
  .stack-tag { font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink-muted); border:1px solid var(--rule); padding:4px 10px; border-radius:2px; font-weight:400; }
</style>
