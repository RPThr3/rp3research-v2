---
import Layout from './Layout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'research'>;
  categoryLabel: string;
}

const { post, categoryLabel } = Astro.props;
const { title, date, readTime } = post.data;
const formattedDate = date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---
<Layout title={`${title} — RP3 Research`}>
  <div class="post-page">

    <header class="post-header">
      <div class="container">
        <a href="/research" class="post-back">← Research</a>
        <div class="post-header-inner">
          <div class="post-eyebrow">
            <span class="post-category">{categoryLabel}</span>
            <span class="post-divider">·</span>
            <span class="post-date-label">{formattedDate}</span>
          </div>
          <h1 class="post-headline">{title}</h1>
          <div class="post-byline">
            <span class="byline-author">Reed Perry</span>
            <span class="byline-sep">·</span>
            <span class="byline-org">RP3 Research</span>
            <span class="byline-sep">·</span>
            <span class="byline-read">{readTime} min read</span>
          </div>
        </div>
      </div>
    </header>

    <article class="post-article">
      <div class="container">
        <div class="post-content">
          <slot />
          <footer class="post-footer">
            <div class="post-sig">
              <span class="sig-dash">—</span>
              <div class="sig-text">
                <span class="sig-name">Reed Perry</span>
                <span class="sig-org">RP3 Research</span>
              </div>
            </div>
            <a href="/research" class="post-back-bottom">← Back to Research</a>
          </footer>
        </div>
      </div>
    </article>

  </div>
</Layout>

<style>
  .post-page { padding-top:var(--nav-h); }
  .post-header { padding-block:clamp(48px,8vw,96px) clamp(40px,6vw,72px); border-bottom:1px solid var(--rule); }
  .post-back { display:inline-flex; align-items:center; font-size:12px; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink-faint); margin-bottom:40px; transition:color 0.2s; }
  .post-back:hover { color:var(--accent); }
  .post-header-inner { max-width:800px; }
  .post-eyebrow { display:flex; align-items:center; gap:12px; margin-bottom:20px; }
  .post-category { font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:var(--accent); font-weight:500; }
  .post-divider { color:var(--ink-faint); font-size:11px; }
  .post-date-label { font-size:11px; color:var(--ink-faint); letter-spacing:0.06em; }
  .post-headline { font-family:var(--font-display); font-size:clamp(32px,4.5vw,60px); font-weight:300; line-height:1.1; letter-spacing:-0.01em; color:var(--ink); margin-bottom:28px; }
  .post-byline { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
  .byline-author { font-size:13px; color:var(--ink); font-weight:400; }
  .byline-sep { color:var(--ink-faint); font-size:11px; }
  .byline-org { font-size:13px; color:var(--ink-muted); font-weight:300; }
  .byline-read { font-size:12px; color:var(--ink-faint); }
  .post-article { padding-block:clamp(56px,8vw,100px); }
  .post-content { max-width:720px; }
  /* Prose styles for MDX content */
  .post-content :global(h2) { font-family:var(--font-display); font-size:clamp(20px,2vw,28px); font-weight:400; color:var(--ink); line-height:1.2; margin-bottom:20px; margin-top:clamp(44px,6vw,64px); }
  .post-content :global(h2:first-child) { margin-top:0; }
  .post-content :global(p) { font-size:16px; line-height:1.9; color:var(--ink-muted); font-weight:300; margin-bottom:16px; }
  .post-content :global(p:last-child) { margin-bottom:0; }
  .post-content :global(.updating-note) { font-size:13px; color:var(--ink-faint); font-style:italic; font-weight:300; margin-bottom:4px; }
  .post-footer { padding-top:clamp(40px,6vw,64px); border-top:1px solid var(--rule); display:flex; align-items:center; justify-content:space-between; gap:24px; flex-wrap:wrap; margin-top:clamp(44px,6vw,64px); }
  .post-sig { display:flex; align-items:center; gap:16px; }
  .sig-dash { font-family:var(--font-display); font-size:24px; color:var(--accent); line-height:1; }
  .sig-text { display:flex; flex-direction:column; gap:2px; }
  .sig-name { font-family:var(--font-display); font-size:18px; font-weight:400; color:var(--ink); }
  .sig-org { font-size:12px; color:var(--ink-faint); letter-spacing:0.06em; }
  .post-back-bottom { font-size:12px; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink-faint); transition:color 0.2s; }
  .post-back-bottom:hover { color:var(--accent); }
</style>
