<style>
  .post-page { padding-top:var(--nav-h); padding-bottom:clamp(80px,12vw,160px); }
  .container { max-width:780px; }

  .back-link { display:inline-block; font-size:12px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-muted); margin-block:clamp(32px,4vw,56px); transition:color 0.2s; }
  .back-link:hover { color:var(--ink); }
  .back-link--bottom { margin-top:64px; margin-bottom:0; }

  /* Header */
  .post-header { margin-bottom:64px; }
  .post-meta { display:flex; align-items:center; gap:8px; margin-bottom:24px; flex-wrap:wrap; }
  .post-category { font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:var(--accent); font-weight:500; }
  .post-dot { color:var(--ink-faint); font-size:12px; }
  .post-date, .post-read { font-size:12px; color:var(--ink-faint); letter-spacing:0.04em; }
  .post-headline { font-family:var(--font-display); font-size:clamp(28px,4vw,52px); font-weight:300; line-height:1.1; letter-spacing:-0.01em; color:var(--ink); margin-bottom:24px; }
  .post-byline { font-size:13px; color:var(--ink-muted); font-weight:300; }
  .byline-name { font-weight:400; color:var(--ink); }

  /* Episode callout */
  .episode-callout { background:var(--paper-warm); border:1px solid var(--rule); border-left:3px solid var(--accent); padding:24px 28px; border-radius:2px; margin-block:36px; }
  .callout-label { display:block; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-faint); font-weight:500; margin-bottom:10px; }
  .callout-title { font-family:var(--font-display); font-size:20px; font-weight:400; color:var(--ink); margin-bottom:8px; line-height:1.2; }
  .callout-desc { font-size:13px; line-height:1.75; color:var(--ink-muted); font-weight:300; margin-bottom:18px; }
  .callout-links { display:flex; gap:20px; flex-wrap:wrap; }
  .callout-link { display:inline-flex; align-items:center; gap:6px; font-size:13px; font-weight:400; color:var(--accent); letter-spacing:0.02em; transition:opacity 0.2s; }
  .callout-link:hover { opacity:0.7; }

  /* Pull quote */
  .pull-quote { border-left:3px solid var(--accent); padding:20px 28px; margin-block:44px; font-family:var(--font-display); font-size:clamp(20px,2.4vw,28px); font-weight:300; font-style:italic; line-height:1.4; color:var(--ink); }

  /* Body */
  .post-body { display:flex; flex-direction:column; gap:24px; margin-bottom:56px; }
  .post-body h2 { font-family:var(--font-display); font-size:clamp(20px,2.2vw,28px); font-weight:400; color:var(--ink); line-height:1.2; margin-top:16px; margin-bottom:4px; }
  .post-body p { font-size:16px; line-height:1.85; color:var(--ink-muted); font-weight:300; }
  .post-body em { font-style:italic; }
  .content-list { display:flex; flex-direction:column; gap:16px; padding-left:0; list-style:none; }
  .content-list li { font-size:16px; line-height:1.85; color:var(--ink-muted); font-weight:300; padding-left:20px; position:relative; }
  .content-list li::before { content:'—'; position:absolute; left:0; color:var(--accent); font-size:14px; top:2px; }
  .content-list li strong { color:var(--ink); font-weight:500; }

  /* Attribution */
  .post-attribution { font-size:12px; color:var(--ink-faint); font-style:italic; font-weight:300; line-height:1.7; margin-bottom:48px; }

  /* Signature */
  .post-signature { margin-bottom:8px; }
  .sig-rule { height:1px; background:var(--rule); margin-bottom:24px; }
  .sig-inner { display:flex; flex-direction:column; gap:4px; }
  .sig-name { font-family:var(--font-display); font-size:20px; font-weight:400; color:var(--ink); }
  .sig-title { font-size:12px; color:var(--ink-faint); letter-spacing:0.06em; font-weight:300; }
</style>
