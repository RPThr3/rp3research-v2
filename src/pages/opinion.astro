---
import Layout from '../layouts/Layout.astro';

const recommendations = [
  {
    category: 'Book',
    asin: '0805073698',
    title: 'Why Zebras Don\'t Get Ulcers',
    author: 'Robert M. Sapolsky',
    description: 'Stanford biologist and MacArthur "Genius Grant" recipient Robert Sapolsky makes the case that chronic psychological stress — the kind only humans manufacture — is slowly killing us. Zebras sprint from lions and move on. We lie awake worrying about mortgages. This book explains what that difference does to your cardiovascular system, immune function, memory, and sleep — and what to do about it.',
    why: 'I think about this book constantly in the context of organizational design and product work. The research on stress and decision-making quality has direct implications for how teams and products should be built.',
    link: 'https://www.amazon.com/dp/0805073698?tag=rp3research-20',
  },
  {
    category: 'Book',
    asin: '1633697975',
    title: 'The Experience Economy',
    author: 'B. Joseph Pine II & James H. Gilmore',
    description: 'Published in 1999 and more relevant today than when it was written. Pine and Gilmore argued that goods and services were no longer enough — that the next competitive frontier was the staging of memorable experiences. The framework of commodity → product → service → experience → transformation is one of the clearest mental models in business strategy.',
    why: 'If you work in financial product design and haven\'t read this, you\'re missing the theoretical foundation for almost everything the industry is trying to build. Banking is not a commodity — or it shouldn\'t be.',
    link: 'https://www.amazon.com/dp/1633697975?tag=rp3research-20',
  },
  {
    category: 'Book',
    asin: '1324035439',
    title: 'A Random Walk Down Wall Street',
    author: 'Burton G. Malkiel',
    description: 'First published in 1973, now in its 13th edition with over 1.5 million copies sold. Malkiel makes the empirical case that markets are efficient, active stock picking consistently underperforms index funds over time, and that the boring, disciplined approach to investing is almost always the right one.',
    why: 'Every person with a 401k should read this once. It will permanently change how you think about financial media, market predictions, and where your money should actually go.',
    link: 'https://www.amazon.com/dp/1324035439?tag=rp3research-20',
  },
  {
    category: 'Book',
    asin: '0385523882',
    title: 'Buyology',
    author: 'Martin Lindstrom',
    description: 'Lindstrom spent three years and $7 million running neuromarketing experiments — using brain scans to study what actually drives purchasing decisions. The results contradict most of what companies believe about advertising, branding, and consumer motivation. Warning labels on cigarettes increase desire. Religion and brand loyalty activate the same neural pathways.',
    why: 'This is the empirical companion to the behavioral thesis that runs through everything I write. People don\'t know why they do what they do — and that gap is where product strategy lives.',
    link: 'https://www.amazon.com/dp/0385523882?tag=rp3research-20',
  },
];

const opinions = [
  {
    title: 'Tampa Is the City Everyone Should Be Paying Attention To',
    description: '170 net new residents per day. JPMorgan processing $10 trillion in daily payments from Highland Oaks. The best airport in America. And a cosmic country guitarist you need to hear before everyone else catches on.',
    date: 'April 12, 2026',
    slug: 'tampa-city-to-watch',
    tags: ['Opinion', 'Cities', 'Finance', 'Music'],
    placeholder: false,
  },
  {
    title: 'Formula 1 Isn\'t a Sport. It\'s a Perfectly Engineered Business System.',
    description: 'Liberty Media didn\'t just buy a racing series. They rebuilt the commercial architecture of a global entertainment platform — and the result is one of the most elegant business systems I\'ve studied.',
    date: 'March 25, 2026',
    slug: 'f1-business-system',
    tags: ['Opinion', 'Strategy', 'Acquired', 'F1'],
    placeholder: false,
  },
  {
    title: 'Rolex: How a Watch Brand Became a Status Operating System',
    description: 'Coming soon.',
    date: '',
    slug: '',
    tags: ['Opinion', 'Strategy', 'Acquired', 'Luxury'],
    placeholder: true,
    comingSoon: true,
  },
];
---
<Layout title="Opinion — RP3 Research">
  <div class="opinion-page">

    <!-- Page header -->
    <header class="opinion-header">
      <div class="container">
        <p class="section-label">Opinion</p>
        <h1 class="opinion-headline">Takes worth having.</h1>
        <p class="opinion-subtext">Recommendations and perspectives from 8+ years at the intersection of fintech, product, and strategy.</p>
      </div>
    </header>

    <!-- Section 1: Recommendations -->
    <section class="section recommendations-section" id="recommendations">
      <div class="container">
        <div class="section-intro observe">
          <p class="section-label">What I'm Reading, Using &amp; Recommending</p>
          <p class="section-sub">Books, products, and services worth your attention — things I've personally used and found genuinely useful.</p>
        </div>
        <div class="rec-list">
          {recommendations.map((rec, i) => (
            <article class="rec-card observe" style={`--delay:${i * 0.1}s`}>
              <div class="rec-card-inner">
                <div class="rec-cover-wrap">
                  <img
                    src={`https://images-na.ssl-images-amazon.com/images/P/${rec.asin}.jpg`}
                    alt={`Cover of ${rec.title}`}
                    class="rec-cover"
                    width="80"
                    height="120"
                  />
                </div>
                <div class="rec-text">
                  <span class="rec-cat">{rec.category}</span>
                  <h3 class="rec-title">{rec.title}</h3>
                  <p class="rec-author">{rec.author}</p>
                  <p class="rec-desc">{rec.description}</p>
                  <p class="rec-why"><em>Why it's on this list:</em> {rec.why}</p>
                  {rec.link && (
                    <a href={rec.link} target="_blank" rel="noopener noreferrer" class="rec-buy-link">Buy on Amazon →</a>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
        <p class="affiliate-note">Some links on this page are affiliate links. If you purchase through them, I may earn a small commission at no extra cost to you.</p>
      </div>
    </section>

    <!-- Divider -->
    <div class="section-divider"><div class="container"><hr class="divider-rule" /></div></div>

    <!-- Section 2: Opinion pieces -->
    <section class="section opinion-section" id="opinion-pieces">
      <div class="container">
        <div class="section-intro observe">
          <p class="section-label">Opinion</p>
          <p class="section-sub">Takes on financial systems, product strategy, and consumer behavior. Shorter form than research. More direct.</p>
        </div>
        <div class="opinion-list">
          {opinions.map((piece, i) => (
            <article class={`opinion-card observe${piece.placeholder ? ' opinion-card--placeholder' : ''}`} style={`--delay:${i * 0.1}s`}>
              <div class="opinion-card-inner">
                <div class="opinion-left">
                  <div class="opinion-top-row">
                    {piece.date && <span class="opinion-date">{piece.date}</span>}
                    {piece.comingSoon && <span class="opinion-badge">Coming Soon</span>}
                  </div>
                  <h3 class="opinion-title">
                    {piece.slug ? <a href={`/opinion/${piece.slug}`}>{piece.title}</a> : piece.title}
                  </h3>
                  {!piece.comingSoon && <p class="opinion-desc">{piece.description}</p>}
                  {piece.tags && piece.tags.length > 0 && !piece.comingSoon && (
                    <ul class="opinion-tags">
                      {piece.tags.map(tag => <li>{tag}</li>)}
                    </ul>
                  )}
                </div>
                {piece.slug && (
                  <div class="opinion-right">
                    <a href={`/opinion/${piece.slug}`} class="opinion-read-link">
                      <span>Read</span>
                      <span class="opinion-arrow">→</span>
                    </a>
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

  </div>
</Layout>
<style>
  .opinion-page { padding-top:var(--nav-h); }

  /* Page header */
  .opinion-header { padding-block:clamp(48px,8vw,96px) clamp(40px,6vw,64px); border-bottom:1px solid var(--rule); }
  .opinion-headline { font-family:var(--font-display); font-size:clamp(36px,5vw,72px); font-weight:300; line-height:1.1; letter-spacing:-0.01em; color:var(--ink); margin-bottom:20px; }
  .opinion-subtext { font-size:clamp(15px,1.5vw,17px); line-height:1.8; color:var(--ink-muted); font-weight:300; max-width:560px; }

  /* Shared section intro */
  .section-intro { margin-bottom:48px; }
  .section-sub { font-size:15px; line-height:1.8; color:var(--ink-muted); font-weight:300; max-width:520px; margin-top:8px; }

  /* Divider */
  .section-divider { padding-block:0; }
  .divider-rule { border:none; border-top:1px solid var(--rule); margin:0; }

  /* Recommendation cards */
  .rec-list { display:flex; flex-direction:column; gap:0; }
  .rec-card { border-bottom:1px solid var(--rule); padding-block:36px; }
  .rec-card:first-child { padding-top:0; }
  .rec-card-inner { display:flex; align-items:flex-start; gap:20px; }
  .rec-cover-wrap { flex-shrink:0; }
  .rec-cover { width:80px; height:120px; object-fit:cover; border:0.5px solid var(--rule); background:var(--paper-warm); display:block; border-radius:1px; }
  .rec-text { flex:1; }
  .rec-cat { display:inline-block; font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:var(--accent); font-weight:500; margin-bottom:8px; }
  .rec-title { font-family:var(--font-display); font-size:clamp(18px,2vw,26px); font-weight:400; color:var(--ink); line-height:1.2; margin-bottom:4px; }
  .rec-author { font-size:12px; color:var(--ink-faint); font-weight:300; font-style:italic; margin-bottom:12px; }
  .rec-desc { font-size:14px; line-height:1.8; color:var(--ink-muted); font-weight:300; margin-bottom:10px; }
  .rec-why { font-size:13px; line-height:1.75; color:var(--ink-muted); font-weight:300; margin-bottom:14px; }
  .rec-why em { font-style:italic; color:var(--ink); }
  .rec-buy-link { font-size:13px; color:var(--accent); font-weight:400; letter-spacing:0.02em; transition:opacity 0.2s; }
  .rec-buy-link:hover { opacity:0.7; }
  .affiliate-note { font-size:11px; color:var(--ink-faint); font-style:italic; font-weight:300; margin-top:28px; padding-top:20px; border-top:1px solid var(--rule); line-height:1.6; }

  /* Opinion piece cards */
  .opinion-list { display:flex; flex-direction:column; gap:0; }
  .opinion-card { border-bottom:1px solid var(--rule); padding-block:36px; }
  .opinion-card:first-child { padding-top:0; }
  .opinion-card--placeholder { opacity:0.45; }
  .opinion-card-inner { display:flex; align-items:flex-start; justify-content:space-between; gap:32px; }
  .opinion-left { flex:1; }
  .opinion-top-row { display:flex; align-items:center; gap:12px; margin-bottom:8px; }
  .opinion-date { font-size:11px; color:var(--ink-faint); letter-spacing:0.06em; }
  .opinion-badge { font-size:9px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-faint); border:1px solid var(--rule); padding:3px 8px; border-radius:2px; font-weight:500; }
  .opinion-title { font-family:var(--font-display); font-size:clamp(20px,2vw,28px); font-weight:400; color:var(--ink); line-height:1.2; margin-bottom:10px; }
  .opinion-title a { transition:color 0.2s; }
  .opinion-title a:hover { color:var(--accent); }
  .opinion-desc { font-size:14px; line-height:1.8; color:var(--ink-muted); font-weight:300; margin-bottom:14px; }
  .opinion-tags { display:flex; flex-wrap:wrap; gap:8px; margin-top:0; }
  .opinion-tags li { font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-faint); border:1px solid var(--rule); padding:4px 10px; border-radius:2px; font-weight:400; }
  .opinion-right { flex-shrink:0; padding-top:4px; }
  .opinion-read-link { display:flex; align-items:center; gap:8px; font-size:13px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-muted); transition:color 0.2s; }
  .opinion-read-link:hover { color:var(--ink); }
  .opinion-read-link:hover .opinion-arrow { transform:translateX(4px); color:var(--accent); }
  .opinion-arrow { font-size:16px; transition:transform 0.25s, color 0.25s; }

  @media (max-width:640px) {
    .rec-card-inner { gap:16px; }
    .opinion-card-inner { flex-direction:column; gap:16px; }
  }
</style>
