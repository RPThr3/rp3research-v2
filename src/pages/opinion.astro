---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Opinion — RP3 Research">
  <div class="opinion-placeholder">
    <div class="container">
      <p class="coming-soon">Coming soon.</p>
    </div>
  </div>
</Layout>
<style>
  .opinion-placeholder { min-height:100svh; display:flex; align-items:center; padding-top:var(--nav-h); }
  .coming-soon { font-family:var(--font-display); font-size:clamp(28px,4vw,48px); font-weight:300; color:var(--ink-muted); letter-spacing:-0.01em; }
</style>
