---
const areas = [
  { num: '01', title: 'Digital Banking', body: 'How consumers relate to their financial institution — trust, engagement, and the behavioral gap between product design intent and actual usage patterns in deposits and savings.' },
  { num: '02', title: 'Money Movement', body: 'The architecture and friction of payments: ACH, Zelle, wire, RDC, bill pay — and how velocity limits, UX design, and fraud signals interact with consumer confidence.' },
  { num: '03', title: 'Product Strategy', body: 'Translating market signals and behavioral data into product roadmap decisions — frameworks for prioritization, vendor evaluation, and executive alignment in financial services.' },
  { num: '04', title: 'Consumer Financial Behavior', body: 'The psychological and structural factors shaping how people save, spend, and move money — applied to product design and financial health program development.' },
];
---
<section class="section focus" id="research">
  <div class="container">
    <p class="section-label">Research Focus</p>
    <div class="focus-header observe">
      <h2 class="focus-headline">Four domains.<br />One through-line.</h2>
      <p class="focus-intro">Every engagement traces back to a core conviction: the hardest problems in fintech are behavioral, not technical.</p>
    </div>
    <div class="focus-grid">
      {areas.map((area, i) => (
        <article class="focus-card observe" style={`--delay:${i * 0.1}s`}>
          <span class="card-num">{area.num}</span>
          <div class="card-body">
            <h3 class="card-title">{area.title}</h3>
            <p class="card-text">{area.body}</p>
          </div>
          <div class="card-accent"></div>
        </article>
      ))}
    </div>
  </div>
</section>
<style>
  .focus { background:var(--paper-warm); border-top:1px solid var(--rule); border-bottom:1px solid var(--rule); }
  .focus-header { display:grid; grid-template-columns:1fr 1fr; gap:48px; margin-bottom:80px; align-items:start; }
  .focus-headline { font-family:var(--font-display); font-size:clamp(36px,4.5vw,64px); font-weight:300; line-height:1.1; letter-spacing:-0.01em; color:var(--ink); }
  .focus-intro { font-size:16px; line-height:1.8; color:var(--ink-muted); padding-top:8px; font-weight:300; max-width:440px; }
  .focus-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:1px; background:var(--rule); border:1px solid var(--rule); }
  .focus-card { position:relative; background:var(--paper-warm); padding:48px 40px 52px; display:flex; flex-direction:column; gap:20px; overflow:hidden; transition:opacity 0.6s cubic-bezier(0.22,1,0.36,1) var(--delay,0s), transform 0.6s cubic-bezier(0.22,1,0.36,1) var(--delay,0s); }
  .focus-card:hover .card-accent { opacity:1; transform:scaleX(1); }
  .card-num { font-family:var(--font-display); font-size:13px; font-weight:400; color:var(--ink-faint); letter-spacing:0.08em; }
  .card-title { font-family:var(--font-display); font-size:clamp(22px,2.2vw,30px); font-weight:400; color:var(--ink); line-height:1.2; }
  .card-text { font-size:14px; line-height:1.8; color:var(--ink-muted); font-weight:300; }
  .card-accent { position:absolute; bottom:0; left:0; width:100%; height:2px; background:var(--accent); opacity:0; transform:scaleX(0); transform-origin:left; transition:opacity 0.3s,transform 0.4s cubic-bezier(0.22,1,0.36,1); }
  @media (max-width:768px) { .focus-header { grid-template-columns:1fr; gap:24px; margin-bottom:48px; } .focus-grid { grid-template-columns:1fr; } .focus-card { padding:36px 28px 40px; } }
</style>
