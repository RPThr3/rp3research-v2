---
interface EarningsRow {
  bank: string;
  revenue?: string;
  netIncome?: string;
  adjNetIncome?: string;
  eps?: string;
  adjEps?: string;
  result?: 'beat' | 'miss' | 'mixed';
  resultNote?: string;
  placeholder?: boolean;
  placeholderText?: string;
}
interface SeparatorRow {
  separator: true;
  label: string;
}
type Row = EarningsRow | SeparatorRow;

interface Props {
  rows: Row[];
  footnote?: string;
}
const { rows, footnote } = Astro.props;
---
<div class="table-wrap">
  <table class="earnings-table">
    <thead>
      <tr>
        <th>Bank</th>
        <th>Revenue</th>
        <th>Net Income</th>
        <th>EPS</th>
        <th>vs. Estimate</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => {
        if ('separator' in row) {
          return (
            <tr class="peer-separator">
              <td colspan="5"><span class="peer-separator-label">{row.label}</span></td>
            </tr>
          );
        }
        if (row.placeholder) {
          return (
            <tr class="row-placeholder">
              <td class="bank-name">{row.bank}</td>
              <td class="placeholder-cell" colspan="3"><em>{row.placeholderText}</em></td>
              <td><span class="placeholder-badge">Updating</span></td>
            </tr>
          );
        }
        return (
          <tr>
            <td class="bank-name">{row.bank}</td>
            <td>{row.revenue ?? '—'}</td>
            <td>
              {row.netIncome ?? '—'}
              {row.adjNetIncome && <span class="adj-figure">{row.adjNetIncome} adj.</span>}
            </td>
            <td>
              {row.eps ?? '—'}
              {row.adjEps && <span class="adj-figure">{row.adjEps} adj.</span>}
            </td>
            <td>
              {row.result === 'beat' && <span class="result-beat">Beat</span>}
              {row.result === 'miss' && <span class="result-miss">Miss</span>}
              {row.result === 'mixed' && <span class="result-mixed">Mixed</span>}
              {row.resultNote && <span class="result-note"> ({row.resultNote})</span>}
            </td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>
{footnote && <p class="table-footnote">{footnote}</p>}

<style>
  .table-wrap { overflow-x:auto; margin-top:4px; margin-bottom:4px; }
  .earnings-table { width:100%; border-collapse:collapse; font-size:14px; }
  .earnings-table thead tr { border-bottom:2px solid var(--ink); }
  .earnings-table th { font-size:10px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-muted); font-weight:500; font-family:var(--font-body); padding:12px 16px 12px 0; text-align:left; white-space:nowrap; }
  .earnings-table th:last-child { text-align:right; padding-right:0; }
  .earnings-table tbody tr { border-bottom:1px solid var(--rule); }
  .earnings-table td { padding:16px 16px 16px 0; color:var(--ink-muted); font-weight:300; vertical-align:middle; }
  .earnings-table td:last-child { text-align:right; padding-right:0; }
  .bank-name { font-family:var(--font-display); font-size:16px; font-weight:400; color:var(--ink); white-space:nowrap; }
  .adj-figure { font-size:12px; color:var(--ink-faint); display:block; margin-top:2px; }
  .result-beat { color:var(--ink); font-weight:400; }
  .result-miss { color:#b94a48; font-weight:400; }
  .result-mixed { color:var(--ink-muted); font-weight:400; font-style:italic; }
  .result-note { font-size:11px; color:var(--ink-faint); }
  .row-placeholder td { color:var(--ink-faint); opacity:0.65; }
  .row-placeholder .bank-name { color:var(--ink-muted); font-style:italic; opacity:0.7; }
  .row-placeholder em { font-style:italic; font-size:13px; }
  .placeholder-cell { font-style:italic; }
  .placeholder-badge { display:inline-block; font-size:9px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-faint); border:1px solid var(--rule); padding:3px 8px; border-radius:2px; white-space:nowrap; }
  .peer-separator td { padding:10px 0 8px; border-bottom:none; }
  .peer-separator-label { font-size:9px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-faint); font-weight:500; font-family:var(--font-body); }
  .table-footnote { font-size:12px; color:var(--ink-faint); font-style:italic; font-weight:300; line-height:1.7; margin-top:12px; }
</style>
