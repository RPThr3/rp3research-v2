<aside class="sources-block">
  <slot />
</aside>

<style>
  .sources-block { margin-top:clamp(40px,6vw,56px); padding-top:28px; border-top:1px solid var(--rule); }
  .sources-block :global(h2) { font-family:var(--font-display); font-size:clamp(16px,1.6vw,20px); font-weight:400; color:var(--ink); line-height:1.2; margin-bottom:20px; }
  .sources-block :global(h3) { font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-faint); font-weight:500; margin-bottom:10px; margin-top:24px; }
  .sources-block :global(h3:first-of-type) { margin-top:4px; }
  .sources-block :global(ul) { display:flex; flex-direction:column; gap:6px; margin-bottom:4px; list-style:none; padding:0; }
  .sources-block :global(li) { font-size:12px; color:var(--ink-faint); font-weight:300; padding-left:14px; position:relative; line-height:1.5; }
  .sources-block :global(li::before) { content:''; position:absolute; left:0; top:8px; width:6px; height:1px; background:var(--rule); }
  .sources-block :global(a) { color:var(--ink-faint); text-decoration:underline; text-underline-offset:3px; text-decoration-color:var(--rule); transition:color 0.2s, text-decoration-color 0.2s; word-break:break-all; }
  .sources-block :global(a:hover) { color:var(--ink-muted); text-decoration-color:var(--ink-muted); }
</style>
