---
interface Link {
  text: string;
  href: string;
  icon?: 'spotify' | 'youtube' | 'acquired' | 'calendar' | 'external';
}
interface Props {
  label?: string;
  title: string;
  desc?: string;
  links?: Link[];
}
const { label, title, desc, links = [] } = Astro.props;
---
<div class="callout">
  {label && <span class="callout-label">{label}</span>}
  <p class="callout-title">{title}</p>
  {desc && <p class="callout-desc">{desc}</p>}
  {links.length > 0 && (
    <div class="callout-links">
      {links.map(link => (
        <a href={link.href} target="_blank" rel="noopener noreferrer" class="callout-link">
          {link.icon === 'spotify' && (
            <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
          )}
          {link.icon === 'youtube' && (
            <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          )}
          {(link.icon === 'acquired' || link.icon === 'external') && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          )}
          {link.icon === 'calendar' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          )}
          {link.text}
        </a>
      ))}
    </div>
  )}
</div>

<style>
  .callout { background:var(--paper-warm); border:1px solid var(--rule); border-left:3px solid var(--accent); padding:24px 28px; border-radius:2px; margin-block:36px; }
  .callout-label { display:block; font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-faint); font-weight:500; margin-bottom:10px; }
  .callout-title { font-family:var(--font-display); font-size:20px; font-weight:400; color:var(--ink); margin-bottom:8px; line-height:1.2; }
  .callout-desc { font-size:13px; line-height:1.75; color:var(--ink-muted); font-weight:300; margin-bottom:18px; }
  .callout-links { display:flex; gap:20px; flex-wrap:wrap; }
  .callout-link { display:inline-flex; align-items:center; gap:6px; font-size:13px; font-weight:400; color:var(--accent); letter-spacing:0.02em; transition:opacity 0.2s; }
  .callout-link:hover { opacity:0.7; }
</style>
