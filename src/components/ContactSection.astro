---
---
<section class="section contact" id="contact">
  <div class="container">
    <p class="section-label">Connect</p>
    <div class="contact-layout">
      <div class="contact-left observe">
        <h2 class="contact-headline">
          Start a<br />
          conversation.
        </h2>
        <p class="contact-sub">
          Whether you're exploring a research engagement, a strategy collaboration,
          or simply want to trade notes on what's happening in fintech and payments —
          the best place to start is a direct message on LinkedIn.
        </p>
        <p class="contact-note">Based in Charlotte, NC. Open to remote and in-person engagements.</p>
      </div>
      <div class="contact-right observe" style="--delay:0.2s">
        <a href="https://www.linkedin.com/in/richardperryrp3/" target="_blank" rel="noopener noreferrer" class="contact-cta-block">
          <div class="cta-content">
            <span class="cta-label">LinkedIn</span>
            <span class="cta-desc">Message directly — preferred channel for new conversations</span>
          </div>
          <span class="cta-arrow">→</span>
        </a>
        <a href="mailto:richard.perry@alumni.unc.edu" class="contact-cta-block contact-cta-secondary">
          <div class="cta-content">
            <span class="cta-label">Email</span>
            <span class="cta-desc">richard.perry@alumni.unc.edu</span>
          </div>
          <span class="cta-arrow">→</span>
        </a>
        <div class="contact-areas">
          <p class="areas-label">Open to conversations on</p>
          <ul>
            <li>Research &amp; analysis engagements</li>
            <li>Product strategy advisory</li>
            <li>Fintech market briefs</li>
            <li>Speaking &amp; panel participation</li>
            <li>Consulting partnerships</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
<style>
  .contact { background:var(--paper-warm); border-top:1px solid var(--rule); }
  .contact-layout { display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:start; }
  .contact-headline { font-family:var(--font-display); font-size:clamp(40px,5.5vw,80px); font-weight:300; line-height:1.05; letter-spacing:-0.02em; color:var(--ink); margin-bottom:36px; }
  .contact-sub { font-size:15px; line-height:1.85; color:var(--ink-muted); font-weight:300; margin-bottom:20px; }
  .contact-note { font-size:13px; color:var(--ink-faint); letter-spacing:0.02em; }
  .contact-right { display:flex; flex-direction:column; gap:0; }
  .contact-cta-block { display:flex; align-items:center; justify-content:space-between; padding:28px 0; border-bottom:1px solid var(--rule); gap:16px; transition:padding-left 0.2s; cursor:pointer; }
  .contact-cta-block:hover { padding-left:8px; }
  .contact-cta-block:hover .cta-arrow { transform:translateX(4px); color:var(--accent); }
  .cta-content { display:flex; flex-direction:column; gap:4px; }
  .cta-label { font-family:var(--font-display); font-size:22px; font-weight:400; color:var(--ink); line-height:1.2; }
  .cta-desc { font-size:13px; color:var(--ink-muted); font-weight:300; }
  .cta-arrow { font-size:20px; color:var(--ink-faint); transition:transform 0.25s,color 0.25s; flex-shrink:0; }
  .contact-areas { padding-top:32px; }
  .areas-label { font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-faint); margin-bottom:16px; font-weight:500; }
  .contact-areas ul { display:flex; flex-direction:column; gap:10px; }
  .contact-areas li { font-size:13px; color:var(--ink-muted); padding-left:18px; position:relative; font-weight:300; }
  .contact-areas li::before { content:''; position:absolute; left:0; top:9px; width:8px; height:1px; background:var(--accent); }
  @media (max-width:768px) { .contact-layout { grid-template-columns:1fr; gap:52px; } }
</style>
