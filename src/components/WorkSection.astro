---
const roles = [
  {
    org: 'Ally Financial',
    title: 'Product & Strategy — Consumer Banking',
    period: '4 Years',
    location: 'Charlotte, NC',
    highlights: [
      'Led go-to-market strategy for Ally\'s flagship Savings Buckets product, scaling balances significantly through targeted merchandising, pricing optimization, and digital feature launches — anchoring Ally\'s shift from rate-dependent to feature-led member acquisition.',
      'Delivered measurable deposit strategy outcomes including cost of funds reduction, NIM improvement, and a favorable deposit beta, providing leadership with a resilient, rate-insensitive funding base during periods of significant macro disruption.',
      'Owned product strategy end-to-end for Savings Buckets, Budgeting, Subscription Management, and Credit Monitoring — driving strong balance retention and primacy conversion for Ally\'s highest-value customer segment.',
      'Built and deployed an in-house AI/ML model for Surprise Savings, replacing a third-party vendor solution and generating significant annual cost savings — recognized as one of the division\'s top wins of the year.',
      'Served as Responsible Owner for five strategic fintech vendor partnerships (Fiserv, Plaid, MX, Equifax, Array), negotiating meaningful savings across a multi-year contract portfolio.',
      'Led a team of 4 direct reports while directing 20+ cross-functional partners across Marketing, Technology, Risk, Analytics, and Pricing.',
    ],
    tags: ['Product Strategy','Deposits','Payments','Go-to-Market','AI/ML'],
  },
  {
    org: 'Booz Allen Hamilton',
    title: 'Consultant — Federal Strategy Consulting',
    period: '3 Years',
    location: 'Washington, DC',
    highlights: [
      'Led large-scale digital transformation programs for the Department of Veterans Affairs and Department of Defense, designing strategic roadmaps that modernized federal digital services for millions of veterans and active-duty personnel.',
      'Managed complex, multi-stakeholder program environments — translating ambiguous policy mandates into actionable product and technology strategies across IT, compliance, legal, and operations.',
      'Developed frameworks for program governance, performance measurement, OKR alignment, and change management in high-compliance, mission-critical technology contexts.',
      'Managed a cross-functional delivery team producing C-suite and senior federal official briefings under tight timelines and high-stakes conditions.',
    ],
    tags: ['Digital Modernization','Program Management','Federal Health','Human-Centered Design'],
  },
  {
    org: 'The Lewin Group (UnitedHealth Group)',
    title: 'Analyst — Strategy Consulting',
    period: '2 Years',
    location: 'Washington, DC',
    highlights: [
      'Built analytical models to assess healthcare cost and utilization trends, informing pricing strategy and product positioning decisions across regional client portfolios.',
      'Partnered with actuaries and product teams to translate complex data insights into strategic recommendations, presenting findings to senior leadership to guide planning and cost containment initiatives.',
      'Recruited directly by Booz Allen Hamilton following a subcontract engagement on a large-scale federal program, where performance led to a full-time offer.',
    ],
    tags: ['Health Policy','Strategy Consulting','Analytics','Market Research'],
  },
];
const education = [
  { degree: 'MBA', school: 'UNC Kenan-Flagler Business School', year: '2023' },
  { degree: 'BA, Business', school: 'Franklin & Marshall College', year: '2018' },
];
---
<section class="section work" id="work">
  <div class="container">
    <p class="section-label">Experience</p>
    <div class="work-layout">
      <div class="work-roles">
        {roles.map((role, i) => (
          <article class="role observe" style={`--delay:${i * 0.15}s`}>
            <div class="role-meta">
              <span class="role-org">{role.org}</span>
              <span class="role-period">{role.period}</span>
            </div>
            <h3 class="role-title">{role.title}</h3>
            <span class="role-location">{role.location}</span>
            <ul class="role-highlights">
              {role.highlights.map(h => <li>{h}</li>)}
            </ul>
            <div class="role-tags">
              {role.tags.map(t => <span class="tag">{t}</span>)}
            </div>
          </article>
        ))}
      </div>
      <aside class="work-sidebar observe" style="--delay:0.3s">
        <div class="sidebar-block">
          <h4 class="sidebar-label">Education</h4>
          {education.map(e => (
            <div class="edu-item">
              <span class="edu-degree">{e.degree}</span>
              <span class="edu-school">{e.school}</span>
              <span class="edu-year">{e.year}</span>
            </div>
          ))}
        </div>
        <div class="sidebar-block">
          <h4 class="sidebar-label">Core Capabilities</h4>
          <ul class="cap-list">
            <li>Product Roadmap & Prioritization</li>
            <li>Fintech Vendor Evaluation</li>
            <li>Executive Communication</li>
            <li>Consumer Behavior Analysis</li>
            <li>Payments Architecture</li>
            <li>Financial Health Program Design</li>
            <li>Cross-functional Leadership</li>
          </ul>
        </div>
        <div class="sidebar-block sidebar-cta">
          <p>Interested in a collaboration or research engagement?</p>
          <a href="#contact" class="btn-primary">Get in Touch</a>
        </div>
      </aside>
    </div>
  </div>
</section>
<style>
  .work-layout { display:grid; grid-template-columns:1fr 300px; gap:80px; align-items:start; }
  .work-roles { display:flex; flex-direction:column; gap:0; }
  .role { padding-block:48px; border-bottom:1px solid var(--rule); }
  .role:first-child { padding-top:0; }
  .role-meta { display:flex; justify-content:space-between; align-items:baseline; gap:12px; margin-bottom:10px; flex-wrap:wrap; }
  .role-org { font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--accent); font-weight:500; }
  .role-period { font-size:12px; color:var(--ink-faint); letter-spacing:0.04em; }
  .role-title { font-family:var(--font-display); font-size:clamp(22px,2.5vw,32px); font-weight:400; color:var(--ink); line-height:1.2; margin-bottom:6px; }
  .role-location { font-size:12px; color:var(--ink-faint); display:block; margin-bottom:28px; }
  .role-highlights { display:flex; flex-direction:column; gap:10px; margin-bottom:28px; }
  .role-highlights li { font-size:14px; line-height:1.7; color:var(--ink-muted); padding-left:20px; position:relative; font-weight:300; }
  .role-highlights li::before { content:''; position:absolute; left:0; top:10px; width:8px; height:1px; background:var(--accent); }
  .role-tags { display:flex; flex-wrap:wrap; gap:8px; }
  .tag { font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-muted); border:1px solid var(--rule); padding:4px 10px; border-radius:2px; }
  .work-sidebar { position:sticky; top:calc(var(--nav-h) + 32px); display:flex; flex-direction:column; gap:40px; }
  .sidebar-block { padding-bottom:36px; border-bottom:1px solid var(--rule); }
  .sidebar-block:last-child { border-bottom:none; padding-bottom:0; }
  .sidebar-label { font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:var(--ink-muted); margin-bottom:20px; font-weight:500; }
  .edu-item { display:flex; flex-direction:column; gap:3px; margin-bottom:20px; }
  .edu-degree { font-family:var(--font-display); font-size:18px; font-weight:400; color:var(--ink); }
  .edu-school { font-size:13px; color:var(--ink-muted); line-height:1.4; }
  .edu-year { font-size:11px; color:var(--ink-faint); }
  .cap-list { display:flex; flex-direction:column; gap:10px; }
  .cap-list li { font-size:13px; color:var(--ink-muted); padding-left:16px; position:relative; font-weight:300; line-height:1.5; }
  .cap-list li::before { content:''; position:absolute; left:0; top:9px; width:6px; height:1px; background:var(--rule); }
  .sidebar-cta { background:var(--paper-warm); border:1px solid var(--rule)!important; padding:28px!important; border-radius:2px; }
  .sidebar-cta p { font-size:14px; color:var(--ink-muted); line-height:1.6; margin-bottom:20px; font-weight:300; }
  .btn-primary { display:inline-block; padding:12px 24px; background:var(--ink); color:var(--paper); font-size:12px; letter-spacing:0.1em; text-transform:uppercase; font-weight:500; border-radius:2px; transition:background 0.2s; }
  .btn-primary:hover { background:#2a2a2a; }
  @media (max-width:960px) { .work-layout { grid-template-columns:1fr; gap:60px; } .work-sidebar { position:static; } }
</style>
