---
---
<section class="hero" id="home">
  <div class="hero-inner container">
    <p class="hero-eyebrow anim anim-d1">Independent Research &nbsp;·&nbsp; Charlotte, NC</p>
    <h1 class="hero-headline anim anim-d2">
      Where financial <em>behavior</em> meets product strategy.
    </h1>
    <p class="hero-sub anim anim-d3">
      RP3 Research produces independent analysis at the intersection of
      digital banking, money movement, and consumer financial behavior —
      translating complexity into product decisions that matter.
    </p>
    <ul class="hero-tags anim anim-d4">
      <li>Digital Banking</li>
      <li>Payments &amp; Money Movement</li>
      <li>Consumer Financial Strategy</li>
      <li>Product Intelligence</li>
    </ul>
    <div class="hero-ctas anim anim-d5">
      <a href="#research" class="btn-primary">View Research</a>
      <a href="#about" class="btn-ghost">About RP3</a>
    </div>
    <div class="hero-rule anim anim-d5">
      <span class="stat"><strong>8+</strong> years fintech &amp; strategy</span>
      <span class="rule-line"></span>
      <span class="stat"><strong>Ally Financial</strong> · Booz Allen Hamilton</span>
    </div>
  </div>
  <div class="hero-ambient" aria-hidden="true">R</div>
</section>
<style>
  .hero { position:relative; min-height:100svh; display:flex; align-items:center; overflow:hidden; padding-top:var(--nav-h); }
  .hero::before { content:''; position:absolute; inset:0; background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E"); background-size:200px; pointer-events:none; opacity:0.5; }
  .hero-inner { position:relative; z-index:1; padding-block:clamp(80px,14vw,180px); }
  .hero-eyebrow { font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:var(--ink-muted); margin-bottom:36px; font-weight:400; }
  .hero-headline { font-family:var(--font-display); font-size:clamp(28px,3.2vw,46px); font-weight:300; line-height:1.15; letter-spacing:-0.02em; color:var(--ink); margin-bottom:40px; }
  .hero-headline em { font-style:italic; color:var(--accent); }
  .hero-sub { font-size:clamp(15px,1.6vw,18px); line-height:1.75; color:var(--ink-muted); max-width:520px; margin-bottom:48px; font-weight:300; }
  .hero-tags { display:flex; flex-wrap:wrap; gap:10px; margin-bottom:52px; }
  .hero-tags li { font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-muted); border:1px solid var(--rule); padding:6px 14px; border-radius:2px; font-weight:400; }
  .hero-ctas { display:flex; gap:16px; flex-wrap:wrap; margin-bottom:72px; }
  .btn-primary { display:inline-block; padding:14px 32px; background:var(--ink); color:var(--paper); font-size:13px; letter-spacing:0.1em; text-transform:uppercase; font-weight:500; border-radius:2px; transition:background 0.2s,transform 0.2s; }
  .btn-primary:hover { background:#2a2a2a; transform:translateY(-1px); }
  .btn-ghost { display:inline-block; padding:14px 32px; border:1px solid rgba(14,14,14,0.25); color:var(--ink-muted); font-size:13px; letter-spacing:0.1em; text-transform:uppercase; font-weight:400; border-radius:2px; transition:border-color 0.2s,color 0.2s; }
  .btn-ghost:hover { border-color:var(--ink); color:var(--ink); }
  .hero-rule { display:flex; align-items:center; gap:24px; flex-wrap:wrap; }
  .stat { font-size:12px; color:var(--ink-muted); letter-spacing:0.04em; }
  .stat strong { color:var(--ink); font-weight:500; }
  .rule-line { flex:1; height:1px; background:var(--rule); min-width:40px; }
  .hero-ambient { position:absolute; right:-0.05em; bottom:-0.15em; font-family:var(--font-display); font-size:clamp(280px,40vw,680px); font-weight:300; line-height:1; color:transparent; -webkit-text-stroke:1px rgba(14,14,14,0.06); pointer-events:none; user-select:none; z-index:0; }
  @media (max-width:600px) { .hero-ambient { display:none; } .hero-inner { padding-block:60px 80px; } }
</style>
